  Tool calls: [{'name': 'write_document', 'args': {'content': "## 🎯 Vision Statement\nTo cultivate a thriving, focused, and well-being-centered workplace by making premium, organic tea an effortless daily ritual for every employee.\n\n## 🚀 Mission Statement\nWe deliver meticulously sourced, premium organic teas directly to office environments, empowering employees to enhance their focus, reduce stress, and elevate their daily experience. We partner with organizations to provide a consistent source of quality, sustainable wellness, and a moment of mindful pause in their busy workday.\n\n## 💡 Core Values\n*   **Quality Sourcing:** Committing to the highest standards for organic and premium tea ingredients.\n*   **Employee Wellness:** Prioritizing the mental and physical well-being of every user.\n*   **Seamless Convenience:** Ensuring effortless, reliable, and timely delivery for busy offices.\n*   **Sustainability:** Operating with a deep commitment to eco-friendly and ethical sourcing practices.\n*   **Mindful Presence:** Encouraging a moment of calm and focus within the daily routine.\n\n## 🌟 Brand Promise\nPremium organic tea, delivered effortlessly, to fuel your team's focus and well-being."}, 'id': 'iu4tDJaoiRqKBpsE3u8anW07nSt6N3QU', 'type': 'tool_call'}]
